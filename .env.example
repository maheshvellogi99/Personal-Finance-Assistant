# ── Application ───────────────────────────────────────────────────────────
APP_NAME="Virtual Personal Finance Assistant"
APP_VERSION="0.1.0"
DEBUG=true

# ── Database (PostgreSQL + asyncpg) ───────────────────────────────────────
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finance_db

# ── Auth / JWT ────────────────────────────────────────────────────────────
# IMPORTANT: Generate a secure random key for production
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── AI / Chatbot LLM Providers ────────────────────────────────────────────
# Priority: GEMINI (free) → GROQ (free) → OPENAI (paid) → Built-in
# Set ONLY ONE key for zero-cost operation. The system auto-detects the
# first available provider.
#
# 🟢 RECOMMENDED (Free): Get a Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
# 🟢 Alternative (Free): Get a Groq API key at https://console.groq.com/keys
GROQ_API_KEY=
#
# 🟡 Paid: OpenAI key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
